NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://user:password@localhost:5432/mantua

PRIVY_APP_ID=
PRIVY_APP_SECRET=

UNISWAP_TRADING_API_KEY=

# The Graph decentralized network API key (https://thegraph.com/studio/apikeys/)
# Optional: when present, /api/positions will include pre-Mantua v4 positions
# discovered via the Uniswap v4 Base subgraph.
THE_GRAPH_API_KEY=
UNISWAP_V4_BASE_SUBGRAPH_ID=HNCFA9TyBqpo5qpe6QreQABAA1kV8g46mhkCcicu6v2R

# Circle Developer-Controlled Wallets — agent wallets on Arc Testnet.
# CIRCLE_API_KEY: a Standard API key from the Circle Developer Console.
# CIRCLE_ENTITY_SECRET: your registered 32-byte entity secret (hex).
#   Register it: https://developers.circle.com/wallets/dev-controlled/register-entity-secret
# CIRCLE_WALLET_SET_ID: optional — set it after the first wallet set is
#   created (the id is logged on creation) to reuse it across restarts.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Network gate. Default "testnet" = Arc Testnet (chain 5042002), Circle's
# USDC-gas chain — the whole app (swaps, pools, liquidity, agent) runs on
# Arc. One env var drives chain ID, v4 contract addresses, token registry,
# spending-cap default, and explorer URLs.
MANTUA_NETWORK=testnet

MANTUA_KILL_SWITCH=0
MANTUA_FEE_BPS=10
MANTUA_FEE_RECIPIENT=
MANTUA_FEE_ADMIN_KEY=
