NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://user:password@localhost:5432/mantua

PRIVY_APP_ID=
PRIVY_APP_SECRET=

UNISWAP_TRADING_API_KEY=

# The Graph decentralized network API key (https://thegraph.com/studio/apikeys/)
# Optional: when present, /api/positions will include pre-Mantua v4 positions
# discovered via the Uniswap v4 Base subgraph.
THE_GRAPH_API_KEY=
UNISWAP_V4_BASE_SUBGRAPH_ID=HNCFA9TyBqpo5qpe6QreQABAA1kV8g46mhkCcicu6v2R

# thirdweb Insight — indexed on-chain data for the Analyze/Research feature.
# Create a project at https://thirdweb.com/dashboard and copy the Secret Key
# (server-side; sent as the x-secret-key header). Optional: when present,
# Insight-backed research topics return live on-chain activity; absent ⇒ those
# topics report "not configured" and the rest of Analyze is unaffected.
THIRDWEB_SECRET_KEY=
THIRDWEB_CLIENT_ID=

CDP_PROJECT_ID=
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
CDP_WALLET_SECRET=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Phase 5b: testnet beta gate. Default = "testnet" (Base Sepolia 84532).
# Set to "mainnet" when launching to Base Mainnet (8453). One env var,
# multiple downstream effects: chain ID, v4 contract addresses, token
# registry, spending-cap default (PR #2), explorer URLs.
MANTUA_NETWORK=testnet

MANTUA_KILL_SWITCH=0
MANTUA_FEE_BPS=10
MANTUA_FEE_RECIPIENT=
MANTUA_FEE_ADMIN_KEY=
