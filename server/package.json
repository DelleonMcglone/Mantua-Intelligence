{
  "name": "@mantua/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.10.0",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
