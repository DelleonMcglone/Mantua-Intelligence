{
  "name": "@mantua/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "find src -name '*.test.ts' | xargs tsx --env-file-if-exists=.env --test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@circle-fin/adapter-circle-wallets": "^1.4.1",
    "@circle-fin/adapter-viem-v2": "1.12.1",
    "@circle-fin/bridge-kit": "^1.11.1",
    "@circle-fin/developer-controlled-wallets": "^10.6.0",
    "@circle-fin/smart-contract-platform": "^10.8.0",
    "@circle-fin/unified-balance-kit": "^1.2.1",
    "@privy-io/server-auth": "1.32.5",
    "@vercel/functions": "^3.7.5",
    "@x402/evm": "^2.17.0",
    "@x402/express": "^2.17.0",
    "@x402/extensions": "^2.17.0",
    "@x402/fetch": "^2.17.0",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "express-rate-limit": "8.4.1",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "serverless-http": "^4.0.0",
    "viem": "2.48.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.10.0",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
