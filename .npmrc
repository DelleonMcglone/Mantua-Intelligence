# @circle-fin/developer-controlled-wallets declares an optional peer on
# @solana/codecs-strings@^2, but Privy's @solana/kit pulls in 6.x. The
# mismatch is irrelevant to us (we use Arc/EVM, not Circle's Solana codecs),
# so resolve peers leniently — otherwise Vercel's clean `npm install` fails
# with ERESOLVE. Applies to local + CI for consistent resolution.
legacy-peer-deps=true
