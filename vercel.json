{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run db:migrate -w @mantua/server && npm run build:server && npm run build -w @mantua/client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --no-package-lock --legacy-peer-deps",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/peg-sync", "schedule": "0 8 * * *" },
    { "path": "/api/cron/rebalance", "schedule": "0 9 * * *" },
    { "path": "/api/cron/intents", "schedule": "0 10 * * *" }
  ]
}
