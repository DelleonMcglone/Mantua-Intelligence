# Privy (D-005, D-006 ACCEPTED)
VITE_PRIVY_APP_ID=

# WalletConnect (D-007 ACCEPTED)
VITE_WALLETCONNECT_PROJECT_ID=

# Backend base URL (for API calls in dev)
VITE_API_BASE_URL=http://localhost:3001

# Phase 5b: testnet beta gate. Default = "testnet" (Base Sepolia 84532).
# Set to "mainnet" to flip Privy/wagmi default + token registry + BaseScan
# URLs to Base Mainnet. Server-side has the matching MANTUA_NETWORK env var.
VITE_MANTUA_NETWORK=testnet

# Optional: override the Base RPC (defaults track VITE_MANTUA_NETWORK —
# https://sepolia.base.org for testnet, https://mainnet.base.org for mainnet).
# Use a private RPC (Alchemy, QuickNode) for production-like load testing.
VITE_BASE_RPC_URL=
