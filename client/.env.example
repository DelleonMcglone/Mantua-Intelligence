# Privy (D-005, D-006 ACCEPTED)
VITE_PRIVY_APP_ID=

# WalletConnect (D-007 ACCEPTED)
VITE_WALLETCONNECT_PROJECT_ID=

# Backend base URL. Leave EMPTY in dev so API calls go through the Vite
# proxy (/api -> http://localhost:3001), same-origin. Setting an explicit
# cross-origin URL here triggers CORS preflight failures ("failed to
# fetch") because the dev server has no CORS middleware. Set this only in
# production, to the deployed API host.
VITE_API_BASE_URL=

# Network gate. Default "testnet" = Arc Testnet (chain 5042002). The app
# runs on Arc only; this flips the Privy/wagmi default chain + token
# registry. Server-side has the matching MANTUA_NETWORK env var.
VITE_MANTUA_NETWORK=testnet

# Optional: override the Arc RPC (defaults to
# https://rpc.testnet.arc.network). Use a private RPC (Alchemy, QuickNode)
# for production-like load testing.
VITE_ARC_RPC_URL=
