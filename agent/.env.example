# Arc AgentKit agent — environment.
# Addresses verified from official Arc docs (docs.arc.network, redirecting
# to docs.arc.io) + Arcscan (https://testnet.arcscan.app). Sources are
# recorded in docs/architecture.md. Copy to agent/.env and fill secrets.

# Arc testnet RPC. Override with a private endpoint for production headroom.
ARC_RPC_URL=https://rpc.testnet.arc.network

# Agent signing key (0x + 64 hex). Gas is paid in Arc's native USDC — there
# is NO test ETH on Arc. Fund this address via the Circle faucet
# (https://faucet.circle.com). NEVER commit a real key; agent/.env is gitignored.
AGENT_PRIVATE_KEY=

# ERC-8004 registries (Arc testnet, ERC-1967 proxies — calls target these).
# Source: docs.arc.network/arc/tutorials/register-your-first-ai-agent
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDRESS=0x8004Cb1BF31DAf7788923b405b754f57acEB4272

# ERC-8183 AgenticCommerce (job + USDC escrow), Arc testnet proxy.
# Source: docs.arc.network/arc/tutorials/create-your-first-erc-8183-job
AGENTIC_COMMERCE_ADDRESS=0x0747EEf0706327138c69792bF28Cd525089e4583

# Allowlisted assets (the ONLY three the agent may operate on).
# USDC + EURC: Circle official Arc testnet docs. USDC is also the gas token
# (18-decimal native), but this ERC-20 address is the 6-decimal interface.
USDC_ADDRESS=0x3600000000000000000000000000000000000000
EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
# cirBTC (8 decimals): repo-sourced (Mantua token registry), NOT in Circle's
# official Arc docs. Verify against an official source before mainnet use.
CIRBTC_ADDRESS=0xf0C4a4CE82A5746AbAAd9425360Ab04fbBA432BF

# Warn when the agent's native USDC gas balance drops below this many USDC.
LOW_GAS_WARN_USDC=1
